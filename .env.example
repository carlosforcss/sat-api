DATABASE_URL=postgres://postgres:postgres@localhost:5432/satcli
RUST_LOG=info,chromiumoxide=off
JWT_SECRET=change-me
UPLOAD_PATH=/data/credentials
TWOCAPTCHA_API_KEY=your-2captcha-api-key
CREDENTIAL_ENCRYPTION_KEY=your-32-byte-encryption-key

# AWS / S3
S3_BUCKET=sat-api-local
AWS_REGION=us-east-1

# MinIO — used for local development (docker compose up minio)
AWS_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
